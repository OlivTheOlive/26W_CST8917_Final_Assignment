{
  "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "functionBaseUrl": {
      "type": "string",
      "defaultValue": "https://YOUR-FUNCTION-APP.azurewebsites.net",
      "metadata": {
        "description": "Function App URL (no trailing slash). Replace with your deployed app."
      }
    }
  },
  "triggers": {
    "ReceiveExpenseHttp": {
      "type": "Request",
      "kind": "Http",
      "inputs": {
        "schema": {
          "type": "object",
          "properties": {
            "employee_name": { "type": "string" },
            "employee_email": { "type": "string" },
            "amount": { "type": "number" },
            "category": { "type": "string" },
            "description": { "type": "string" },
            "manager_email": { "type": "string" }
          },
          "required": [
            "employee_name",
            "employee_email",
            "amount",
            "category",
            "description",
            "manager_email"
          ]
        }
      }
    }
  },
  "actions": {
    "Validate_Expense_Function": {
      "type": "Http",
      "inputs": {
        "method": "POST",
        "uri": "@{concat(parameters('functionBaseUrl'), '/api/validate')}",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": "@triggerBody()"
      },
      "runAfter": {}
    },
    "Parse_Validation": {
      "type": "ParseJson",
      "inputs": {
        "content": "@body('Validate_Expense_Function')",
        "schema": {
          "type": "object",
          "properties": {
            "valid": { "type": "boolean" },
            "errors": {
              "type": "array",
              "items": { "type": "string" }
            },
            "normalized": { "type": "object" }
          }
        }
      },
      "runAfter": {
        "Validate_Expense_Function": ["Succeeded"]
      }
    }
  },
  "outputs": {}
}
