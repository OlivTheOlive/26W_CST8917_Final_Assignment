@baseUrl = http://localhost:7070

@instanceId = 486b50a0ff274322b20c355534252bea

### 1) Valid expense under $100 — expected: auto-approved
POST {{baseUrl}}/api/expenses
Content-Type: application/json

{
  "employee_name": "Ada Lovelace",
  "employee_email": "ada@example.com",
  "amount": 42.50,
  "category": "software",
  "description": "IDE subscription",
  "manager_email": "mgr@example.com"
}

### 2) Valid expense >= $100, manager approves — expected: approved
POST {{baseUrl}}/api/expenses
Content-Type: application/json

{
  "employee_name": "Ada Lovelace",
  "employee_email": "ada@example.com",
  "amount": 150.00,
  "category": "software",
  "description": "IDE subscription",
  "manager_email": "mgr@example.com"
}

### Manager approves
POST {{baseUrl}}/api/manager/{{instanceId}}
Content-Type: application/json

{
  "approved": true
}

###############################################################################
### 3) Valid expense >= $100, manager rejects — expected: rejected
POST {{baseUrl}}/api/expenses
Content-Type: application/json

{
  "employee_name": "Alan Turing",
  "employee_email": "alan@example.com",
  "amount": 200.00,
  "category": "equipment",
  "description": "Laptop",
  "manager_email": "mgr@example.com"
}

### Then POST manager decision with approved: false (use new instance id from response)
POST {{baseUrl}}/api/manager/{{instanceId}}
Content-Type: application/json

{
  "approved": false
}

### 4) Valid expense >= $100
POST {{baseUrl}}/api/expenses
Content-Type: application/json

{
  "employee_name": "Edsger Dijkstra",
  "employee_email": "edsger@example.com",
  "amount": 175.00,
  "category": "meals",
  "description": "Team dinner",
  "manager_email": "mgr@example.com",
  "approval_timeout_seconds": 5
}

### 5) Missing required fields — expected: validation error
POST {{baseUrl}}/api/expenses
Content-Type: application/json

{
  "employee_name": "Incomplete",
  "employee_email": "bad@example.com",
  "amount": 10,
  "category": "supplies"
}

### 6) Invalid category — expected: validation error
POST {{baseUrl}}/api/expenses
Content-Type: application/json

{
  "employee_name": "Wrong Cat",
  "employee_email": "cat@example.com",
  "amount": 50,
  "category": "invalid_category",
  "description": "Test",
  "manager_email": "mgr@example.com"
}
